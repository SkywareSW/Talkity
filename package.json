{
  "name": "talkity",
  "version": "1.0.7",
  "description": "Talkity – MSN-inspired real time messenger",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "server": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run start\"",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "release": "electron-builder --publish always"
  },
  "author": "SkywareSW",
  "dependencies": {
    "concurrently": "^8.2.2",
    "electron-updater": "^6.1.7",
    "socket.io-client": "^4.7.4"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.talkity.app",
    "productName": "Talkity",
    "copyright": "Copyright © 2026 Talkity",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "!app/node_modules"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!node_modules"
        ]
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules"
      }
    ],
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "app/icon.ico",
      "sign": null,
      "signingHashAlgorithms": null,
      "signAndEditExecutable": false,
      "signDlls": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "app/icon.ico",
      "uninstallerIcon": "app/icon.ico",
      "installerHeaderIcon": "app/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Talkity"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "app/icon.icns",
      "category": "public.app-category.social-networking",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "Install Talkity",
      "icon": "app/icon.icns"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "app/icon.png",
      "category": "Network"
    }
  }
}
